# ── Broker Mode ──────────────────────────────────────────────
# Options: "paper" | "demo" | "live"
# Start with "paper" (no API keys needed).
# Switch to "demo" when you have Kalshi demo keys.
BROKER_MODE=paper

# ── Kalshi API Credentials ───────────────────────────────────
# Get from https://kalshi.com/account/security
# Leave blank for paper mode.
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=  # path to .pem file, or set KALSHI_PRIVATE_KEY_B64
KALSHI_PRIVATE_KEY_B64=   # base64-encoded private key (alternative to file)

# Kalshi API base URLs (do not change)
KALSHI_LIVE_BASE_URL=https://trading-api.kalshi.com/trade-api/v2
KALSHI_DEMO_BASE_URL=https://demo-trading-api.kalshi.co/trade-api/v2

# ── Database ─────────────────────────────────────────────────
# SQLite for dev. Change to postgresql+asyncpg://... for prod.
DATABASE_URL=sqlite+aiosqlite:///./data/kalshi.db

# ── Paper Trading ─────────────────────────────────────────────
PAPER_INITIAL_BALANCE=10000.0
PAPER_SLIPPAGE_BPS=5.0

# ── Risk Controls ─────────────────────────────────────────────
MAX_POSITION_PCT=0.05          # max 5% of portfolio per position
MAX_PORTFOLIO_EXPOSURE_PCT=0.5 # max 50% of portfolio in open positions
MAX_DAILY_LOSS_PCT=0.10        # circuit breaker: halt if daily loss > 10%
DEFAULT_KELLY_FRACTION=0.25    # quarter-Kelly

# ── Workers ───────────────────────────────────────────────────
MARKET_POLL_INTERVAL_SECONDS=30
STRATEGY_TICK_INTERVAL_SECONDS=60
PNL_CALC_INTERVAL_SECONDS=60

# ── External Data APIs (optional, for nowcasting strategy) ────
BLS_API_KEY=       # https://www.bls.gov/developers/
FRED_API_KEY=      # https://fred.stlouisfed.org/docs/api/api_key.html
NEWS_API_KEY=      # https://newsapi.org/

# ── Alerts (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── App Settings ──────────────────────────────────────────────
APP_NAME=Kalshi Trading Bot
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
